<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.lguconnect">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_lgu_shield"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_lgu_shield"
        android:supportsRtl="true"
        android:theme="@style/Theme.LGUConnect">

        <!-- Splash -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Resident screens -->
        <activity android:name=".activities.LoginActivity"
            android:exported="false" />
        <activity android:name=".activities.MainActivity"
            android:exported="false" />
        <activity android:name=".activities.AnnouncementDetailActivity"
            android:exported="false" />
        <activity android:name=".activities.NotificationsActivity"
            android:exported="false" />
        <activity android:name=".activities.CategoriesActivity"
            android:exported="false" />
        <activity android:name=".activities.ProfileActivity"
            android:exported="false" />

        <!-- Admin screens -->
        <activity android:name=".admin.AdminDashboardActivity"
            android:exported="false" />
        <activity android:name=".admin.PostAnnouncementActivity"
            android:exported="false" />
        <activity android:name=".admin.ManageAnnouncementsActivity"
            android:exported="false" />
        <activity android:name=".admin.ManageCategoriesActivity"
            android:exported="false" />
        <activity android:name=".admin.EmergencyAlertActivity"
            android:exported="false" />
        <activity android:name=".admin.AdminSettingsActivity"
            android:exported="false" />

    </application>
</manifest>
